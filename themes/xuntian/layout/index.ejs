<% if (page.current && page.current > 1) { %>
  <%- partial('_partial/post-list', { posts: page.posts, titleKey: 'archive.title', titleFallback: 'Archive', eyebrow: 'archive' }) %>
<% } else { %>
<section class="home-page page-stack">
  <section class="profile-panel reveal">
    <div class="profile-media">
      <img src="<%- url_for('/pic/profile.JPG') %>" alt="Portrait of Xuntian Rao">
    </div>
    <div class="profile-core">
      <p class="eyebrow">portfolio / shanghai</p>
      <h1>
        <span data-i18n="home.name">饶巡天</span>
        <small>@Raoxuntian</small>
      </h1>
      <p class="status-line"><span></span><span data-i18n="home.status">写软件，也拍照。</span></p>
      <p class="profile-lede" data-i18n="home.lede">
        我关注产品级后端服务、平台工程、搜索推荐和工程效率，也用相机记录街道、晨昏、自然光和那些不太会重复出现的瞬间。
      </p>
      <div class="quick-links">
        <a href="<%- url_for('/resume') %>" data-i18n="home.resume">看简历</a>
        <a href="<%- url_for('/photography') %>" data-i18n="home.photos">看摄影</a>
        <a href="<%- url_for('/archives') %>" data-i18n="home.notes">读文章</a>
      </div>
    </div>
    <div class="profile-stats" aria-label="Profile stats">
      <div><strong>2021</strong><span data-i18n="home.stats.microsoft">加入微软</span></div>
      <div><strong><%= site.posts.length %></strong><span data-i18n="home.stats.posts">篇文章</span></div>
      <div><strong>05</strong><span data-i18n="home.stats.frames">张精选照片</span></div>
      <div class="mini-grid" aria-hidden="true">
        <% for (var i = 0; i < 35; i++) { %>
          <span class="heat heat-<%= (i * 7 + 3) % 5 %>"></span>
        <% } %>
      </div>
    </div>
  </section>

  <section class="section-grid reveal">
    <div class="section-card wide">
      <div class="section-heading">
        <p>01 / about</p>
        <h2 data-i18n="home.about.title">一个工程师和摄影师的工作台</h2>
      </div>
      <p data-i18n="home.about.body">
        这个站点不是简历的包装壳，而是一个更长期的索引：代码、系统、写作、城市和影像都放在同一个空间里。技术页面保持密度，摄影页面保留呼吸感。
      </p>
    </div>
    <div class="section-card metric-card">
      <span>backend</span>
      <strong>C++ / Python / Service</strong>
      <p data-i18n="home.metric.backend">后端服务、平台能力、数据流和质量验证。</p>
    </div>
    <div class="section-card metric-card">
      <span>camera</span>
      <strong>Street / Light / Memory</strong>
      <p data-i18n="home.metric.camera">街头、晨昏和自然光，替普通日子留档。</p>
    </div>
  </section>

  <section class="split-section reveal">
    <div>
      <div class="section-heading compact">
        <p>02 / writing</p>
        <h2 data-i18n="home.writing.title">最近仍值得翻的几篇</h2>
      </div>
      <div class="note-list">
        <a href="<%- url_for('/2020/08/17/processes-and-threads/') %>">
          <span>OS</span>
          <strong>进程和线程</strong>
          <em data-i18n="home.note.one">资源、调度与通信的面试常客。</em>
        </a>
        <a href="<%- url_for('/2020/06/23/computer-networking/') %>">
          <span>Network</span>
          <strong>计网面试题目梳理</strong>
          <em data-i18n="home.note.two">从 OSI 到 TCP/IP，把基础问题串起来。</em>
        </a>
        <a href="<%- url_for('/2021/08/02/essay-202108/') %>">
          <span>Essay</span>
          <strong>随笔 202108</strong>
          <em data-i18n="home.note.three">从北京、武汉到上海，一点生活侧写。</em>
        </a>
      </div>
    </div>
    <div>
      <div class="section-heading compact">
        <p>03 / photography</p>
        <h2 data-i18n="home.photo.title">一些低饱和的清晨</h2>
      </div>
      <div class="photo-strip">
        <img src="<%- url_for('/pic/IMG_0879.JPG') %>" alt="Photo by Xuntian Rao">
        <img src="<%- url_for('/pic/IMG_0880.JPG') %>" alt="Photo by Xuntian Rao">
        <img src="<%- url_for('/pic/IMG_0881.JPG') %>" alt="Photo by Xuntian Rao">
        <img src="<%- url_for('/pic/IMG_0882.JPG') %>" alt="Photo by Xuntian Rao">
      </div>
      <p class="muted" data-i18n="home.photo.body">照片像另一种 commit log，只是记录的不是代码，而是光线经过的方式。</p>
    </div>
  </section>

  <section class="link-row reveal" aria-label="Elsewhere">
    <a href="mailto:377844918@qq.com"><span>contact</span><strong>377844918@qq.com</strong></a>
    <a href="https://github.com/Raoxuntian" target="_blank" rel="noopener"><span>github</span><strong>github.com/Raoxuntian</strong></a>
    <a href="<%- url_for('/resume') %>"><span>resume</span><strong data-i18n="home.resume.link">查看在线简历</strong></a>
  </section>
</section>
<% } %>
