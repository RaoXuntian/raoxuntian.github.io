<section class="archive-page page-stack reveal">
  <% var listEyebrow = typeof eyebrow !== 'undefined' ? eyebrow : 'archive'; %>
  <% var listTitleKey = typeof titleKey !== 'undefined' ? titleKey : 'archive.title'; %>
  <% var listTitleFallback = typeof titleFallback !== 'undefined' ? titleFallback : '文章归档'; %>
  <div class="page-title">
    <p><%= listEyebrow %></p>
    <h1 data-i18n="<%= listTitleKey %>"><%= listTitleFallback %></h1>
  </div>
  <div class="post-list">
    <% posts.sort('date', -1).each(function(post){ %>
      <article class="post-row">
        <time datetime="<%= date(post.date, 'YYYY-MM-DD') %>"><%= date(post.date, 'YYYY.MM.DD') %></time>
        <div>
          <h2><a href="<%- url_for(post.path) %>"><%= post.title || 'Untitled' %></a></h2>
          <% if (post.excerpt) { %>
            <div class="post-excerpt"><%- strip_html(post.excerpt).substring(0, 140) %></div>
          <% } %>
          <% if (post.tags && post.tags.length) { %>
            <div class="tag-line">
              <% post.tags.each(function(tag){ %>
                <a href="<%- url_for(tag.path) %>">#<%= tag.name %></a>
              <% }) %>
            </div>
          <% } %>
        </div>
      </article>
    <% }) %>
  </div>
  <% if (page.total > 1) { %>
    <nav class="pager">
      <%- paginator({ prev_text: 'Prev', next_text: 'Next' }) %>
    </nav>
  <% } %>
</section>
